---
---
<footer class="bg-[#090727]">
    <div class="max-w-8xl mx-auto px-8 xl:px-30 py-10 lg:py-20">
        <div class="grid grid-cols-2 lg:grid-cols-6 xl:grid-cols-5 gap-x-5 gap-y-10 xl:gap-y-5">
            <div class="col-span-2 lg:col-span-3 xl:col-span-2 flex flex-col justify-start items-start gap-y-4">
                <img class="h-13.5 -ml-2.5" src="/images/logo/logo_light.svg" alt="SalesZote Logo" />

                <div class="max-w-96 justify-center text-white text-sm font-medium leading-tight">
                    Sales Zote is a powerful and easy-to-use retail POS solution designed to simplify your sales, inventory, and customer management.
                </div>

                <div class="flex">
                    <a href="https://www.instagram.com/saleszote" target="_blank" rel="noopener noreferrer" onclick="window.posthog?.capture('social_link_clicked', { platform: 'instagram' })" class="w-8 h-8 bg-white flex justify-center items-center rounded-full mr-3">
                        <img src="/images/icons/instagram.svg" alt="SalesZote Instagram" />
                    </a>

                    <a href="https://www.linkedin.com/company/saleszote" target="_blank" rel="noopener noreferrer" onclick="window.posthog?.capture('social_link_clicked', { platform: 'linkedin' })" class="w-8 h-8 bg-white flex justify-center items-center rounded-full mr-3">
                        <img src="/images/icons/linkedin.svg" alt="SalesZote LinkedIn" />
                    </a>

                    <a href="https://web.facebook.com/saleszote" target="_blank" rel="noopener noreferrer" onclick="window.posthog?.capture('social_link_clicked', { platform: 'facebook' })" class="w-8 h-8 bg-white flex justify-center items-center rounded-full">
                        <img src="/images/icons/facebook.svg" alt="SalesZote Facebook" />
                    </a>
                </div>
            </div>

            <div>
                <h6 class="justify-center text-amber-500 text-sm font-bold leading-tight">Quick Links</h6>

                <div class="self-stretch inline-flex flex-col justify-start items-start gap-3.5 mt-6">
                    <a href="https://app.saleszote.com/register" class="self-stretch justify-center text-white text-sm font-medium leading-tight">Create Account</a>
                    <a href="https://app.saleszote.com/login" class="justify-center text-white text-sm font-medium leading-tight">Sign In</a>
                </div>
            </div>

            <div>
                <h6 class="justify-center text-amber-500 text-sm font-bold leading-tight">Get Started</h6>

                <div class="self-stretch inline-flex flex-col justify-start items-start gap-3.5 mt-6">
                    <a href="/contact" class="justify-center text-white text-sm font-medium leading-tight">Request a Feature</a>
                    <a href="/contact" class="justify-center text-white text-sm font-medium leading-tight">Contact Us</a>
                </div>
            </div>

            <div>
                <h6 class="justify-center text-amber-500 text-sm font-bold leading-tight">Mobile App</h6>

                <div class="self-stretch inline-flex flex-col justify-start items-start gap-3.5 mt-6">
                    <a href="https://apps.apple.com/us/app/sales-zote/id6761330158" target="_blank" rel="noopener noreferrer"
                       onclick="window.posthog?.capture('app_download_clicked', { platform: 'ios', source: 'footer' })" class="flex items-center gap-2 text-white text-sm font-medium leading-tight hover:text-amber-400" style="transition: color 150ms ease;">
                        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M11.624 7.222c-.876 0-2.232-.996-3.66-.96-1.884.024-3.612 1.092-4.584 2.784-1.956 3.396-.504 8.412 1.404 11.172.936 1.344 2.04 2.856 3.504 2.808 1.404-.06 1.932-.912 3.636-.912 1.692 0 2.172.912 3.66.876 1.512-.024 2.472-1.368 3.396-2.724 1.068-1.56 1.512-3.072 1.536-3.156-.036-.012-2.94-1.128-2.976-4.488-.024-2.808 2.292-4.152 2.4-4.212-1.32-1.932-3.348-2.148-4.056-2.196-1.848-.144-3.396 1.008-4.26 1.008zm3.12-2.832c.78-.936 1.296-2.244 1.152-3.552-1.116.048-2.46.744-3.264 1.68-.72.828-1.344 2.16-1.176 3.432 1.236.096 2.508-.636 3.288-1.56z"/>
                        </svg>
                        Download on iOS
                    </a>
                    <a href="https://play.google.com/store/apps/details?id=com.saleszote.app" target="_blank" rel="noopener noreferrer"
                       onclick="window.posthog?.capture('app_download_clicked', { platform: 'android', source: 'footer' })" class="flex items-center gap-2 text-white text-sm font-medium leading-tight hover:text-amber-400" style="transition: color 150ms ease;">
                        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3.18 23.76C3.068 23.505 3 23.22 3 22.896V1.104C3 .78 3.068.494 3.18.24L13.55 12 3.18 23.76z" fill="#EA4335"/>
                            <path d="M17.334 16.042l-3.784-3.784L3.18 23.76c.376.41.928.636 1.548.564L17.334 16.042z" fill="#FBBC04"/>
                            <path d="M20.9 10.47L17.334 8.295l-3.784 3.7 3.784 3.784 3.541-2.156a1.877 1.877 0 000-3.153z" fill="#4285F4"/>
                            <path d="M3.18.24L13.55 12l3.784-3.7L4.728-.324C4.108-.396 3.556-.17 3.18.24z" fill="#34A853"/>
                        </svg>
                        Get on Android
                    </a>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-center pt-6 border-t border-white mt-9 gap-x-3.5">
            <div class="justify-start text-white text-xs font-medium">© Copyright 2025. SalesZote LTD</div>
            <div class="w-1.25 h-1.25 bg-neutral-400 rounded-sm"></div>
            <a href="/privacy-policy" class="justify-start text-white text-xs font-medium hover:underline">
                Privacy Policy
            </a>
        </div>
    </div>
</footer>
